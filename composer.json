{
    "name": "nycu-csit/laravel-impersonation",
    "description": "",
    "license": "MIT",
    "type": "library",
    "version": "1.0.0",
    "homepage": "https://gitlab.it.cs.nycu.edu.tw/nycu-csit/laravel-impersonation",
    "require": {
        "laravel/framework": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "orchestra/testbench": "^9.1"
    },
    "autoload": {
        "psr-4": {
            "NycuCsit\\Impersonation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/",
            "NycuCsit\\Impersonation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NycuCsit\\Impersonation\\ImpersonationServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve"
        ],
        "lint": [
            "@php vendor/bin/phpstan analyse"
        ]
    }
}
